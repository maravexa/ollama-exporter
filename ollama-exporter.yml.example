ollama_url: "http://localhost:11434"
listen_addr: ":9400"
poll_interval: "15s"

proxy:
  enabled: true
  listen_addr: ":9401"
  # Paths for which the proxy forwards traffic normally but skips all
  # Prometheus metric recording. The defaults suppress internal polling
  # calls that would otherwise inflate inference histogram cardinality.
  exclude_paths:
    - "/"
    - "/api/ps"
    - "/api/tags"
    - "/api/show"
    - "/api/version"

gpu:
  enabled: true
  # Separate poll interval for GPU sysfs reads; inherits poll_interval if omitted.
  # poll_interval: "5s"
  # Override the sysfs DRM root; useful for testing.
  # sysfs_base: "/sys/class/drm"

log_level: "info"
